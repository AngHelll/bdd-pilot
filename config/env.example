# Optional environment files for BDD Pilot test runs.
#
# Copy this file into your test project's `config/` folder (sibling to the
# folder that contains your `.csproj`, or anywhere above it — BDD Pilot walks
# up from the project directory looking for `config/`).
#
# Files are loaded in memory only when you run tests from VS Code. They are
# never logged, committed by the extension, or sent anywhere.
#
# Naming:
#   config/.env.dev    — loaded when STAGE=dev
#   config/.env.test   — loaded when STAGE=test  (default)
#   config/.env.stg    — loaded when STAGE=stg
#   config/.env.prod   — loaded when STAGE=prod
#   config/.env.local  — optional overrides for any stage (loaded after stage file)
#
# Add real secrets to gitignored copies (e.g. config/.env.test.local) — not to
# tracked files. Keep placeholders here for documentation only.

# Stage marker (BDD Pilot also sets STAGE automatically for each run)
STAGE=test

# Example: API base URL for your test project
# API_BASE_URL=https://api.example.test

# Example: credentials consumed by your step definitions / hooks
# TEST_USER_EMAIL=user@example.com
# TEST_USER_PASSWORD=replace-me

# Example: private NuGet feed token (prefer machine env vars in CI)
# VSTS_NUGET_ACCESS_KEY=

# Example: Playwright / browser toggles
# HEADLESS_MODE=true
# BROWSER=chromium
